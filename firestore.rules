rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isGuardian() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_guardian == true;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isAuth();
      allow update: if isOwner(uid) &&
                       request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    match /incidents/{incidentId} {
      allow read: if isAuth();
      allow create: if isAuth() &&
                       request.resource.data.reported_by_uid == request.auth.uid &&
                       request.resource.data.status == 'active';
      allow update: if isAuth() && (
                       resource.data.reported_by_uid == request.auth.uid ||
                       isAdmin()
                    );
      allow delete: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isAuth() && (
                     resource.data.recipient_uid == request.auth.uid ||
                     isAdmin()
                  );
      allow create: if isAdmin();
      allow update: if isAuth() &&
                       resource.data.recipient_uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /emergency-contacts/{contactId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /service-providers/{providerId} {
      allow read: if isAuth();
      allow create: if isAuth() && isOwner(providerId);
      allow update: if isAuth() && (isOwner(providerId) || isAdmin());
      allow delete: if isAdmin();
    }

  }
}
