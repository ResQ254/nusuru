rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isGuardian() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_guardian == true;
    }

    // ─── USERS collection ───────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isAuth();
      allow update: if isOwner(uid) &&
                       request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    // ─── INCIDENTS collection ────────────────────────────────────────────
    match /incidents/{incidentId} {
      allow read: if isAuth();
      allow create: if isAuth() &&
                       request.resource.data.reported_by_uid == request.auth.uid &&
                       request.resource.data.status == 'active';
      allow update: if isAuth() && (
                       resource.data.reported_by_uid == request.auth.uid ||
                       isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ─── ALERTS collection ───────────────────────────────────────────────
    match /alerts/{alertId} {
      allow read: if isAuth() && (
                     resource.data.recipient_uid == request.auth.uid ||
                     isAdmin()
                  );
      // Alerts are created by the onIncidentCreated Cloud Function via the
      // Admin SDK, which bypasses these rules entirely — this just blocks
      // any direct client-side write attempt.
      allow create: if isAdmin();
      allow update: if isAuth() &&
                       resource.data.recipient_uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── EMERGENCY-CONTACTS collection ───────────────────────────────────
    match /emergency-contacts/{contactId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── SERVICE-PROVIDERS collection ────────────────────────────────────
    match /service-providers/{providerId} {
      allow read: if isAuth();

      // Providers self-register — must write to their own uid-keyed doc
      allow create: if isAuth() && isOwner(providerId);

      // Providers update their own status/location; admins can also manage
      allow update: if isAuth() && (isOwner(providerId) || isAdmin());

      allow delete: if isAdmin();
    }

  }
}